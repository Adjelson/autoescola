<?xml version="1.0" encoding="UTF-8"?>
<!-- web.config — AutoEscola Financeiro para IIS (Dominios.pt) -->
<configuration>
    <system.webServer>
        <rewrite>
            <rules>
                <!-- Bloquear acesso a pastas sensíveis -->
                <rule name="Bloquear config" stopProcessing="true">
                    <match url="^(config|models|controllers|middleware)/" />
                    <action type="AbortRequest" />
                </rule>
            </rules>
        </rewrite>

        <!-- Bloquear listagem de diretórios -->
        <directoryBrowse enabled="false" />

        <!-- Headers de segurança -->
        <httpProtocol>
            <customHeaders>
                <add name="X-Content-Type-Options" value="nosniff" />
                <add name="X-Frame-Options" value="SAMEORIGIN" />
                <add name="X-XSS-Protection" value="1; mode=block" />
            </customHeaders>
        </httpProtocol>
    </system.webServer>
</configuration>
